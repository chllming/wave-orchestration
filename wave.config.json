{
  "version": 1,
  "projectName": "Wave Orchestration",
  "repoMode": "single-repo",
  "defaultLane": "main",
  "paths": {
    "docsDir": "docs",
    "stateRoot": ".tmp",
    "orchestratorStateDir": ".tmp/wave-orchestrator",
    "terminalsPath": ".vscode/terminals.json",
    "context7BundleIndexPath": "docs/context7/bundles.json",
    "componentCutoverMatrixDocPath": "docs/plans/component-cutover-matrix.md",
    "componentCutoverMatrixJsonPath": "docs/plans/component-cutover-matrix.json"
  },
  "roles": {
    "rolePromptDir": "docs/agents",
    "evaluatorAgentId": "A0",
    "integrationAgentId": "A8",
    "documentationAgentId": "A9",
    "evaluatorRolePromptPath": "docs/agents/wave-evaluator-role.md",
    "integrationRolePromptPath": "docs/agents/wave-integration-role.md",
    "documentationRolePromptPath": "docs/agents/wave-documentation-role.md"
  },
  "executors": {
    "default": "codex",
    "profiles": {
      "implement-fast": {
        "id": "codex",
        "tags": ["implementation"],
        "budget": {
          "turns": 12,
          "minutes": 45
        }
      },
      "deep-review": {
        "id": "claude",
        "tags": ["integration", "review"],
        "budget": {
          "turns": 10,
          "minutes": 30
        }
      },
      "docs-pass": {
        "id": "claude",
        "tags": ["documentation"],
        "budget": {
          "turns": 8,
          "minutes": 20
        }
      },
      "ops-triage": {
        "id": "opencode",
        "tags": ["ops", "research"],
        "budget": {
          "turns": 8,
          "minutes": 20
        }
      }
    },
    "codex": {
      "command": "codex",
      "sandbox": "danger-full-access"
    },
    "claude": {
      "command": "claude",
      "appendSystemPromptMode": "append",
      "outputFormat": "text"
    },
    "opencode": {
      "command": "opencode",
      "format": "default"
    }
  },
  "skills": {
    "dir": "skills",
    "base": ["wave-core", "repo-coding-rules"],
    "byRole": {
      "implementation": ["role-implementation"],
      "integration": ["role-integration"],
      "documentation": ["role-documentation"],
      "evaluator": ["role-evaluator"],
      "infra": ["role-infra"],
      "deploy": ["role-deploy"],
      "research": ["role-research"]
    },
    "byRuntime": {
      "codex": ["runtime-codex"],
      "claude": ["runtime-claude"],
      "opencode": ["runtime-opencode"],
      "local": ["runtime-local"]
    },
    "byDeployKind": {
      "railway-cli": ["provider-railway"],
      "railway-mcp": ["provider-railway"],
      "docker-compose": ["provider-docker-compose"],
      "kubernetes": ["provider-kubernetes"],
      "ssh-manual": ["provider-ssh-manual"],
      "custom": ["provider-custom-deploy"]
    }
  },
  "sharedPlanDocs": [
    "docs/plans/current-state.md",
    "docs/plans/master-plan.md",
    "docs/plans/migration.md"
  ],
  "validation": {
    "requiredPromptReferences": [
      "docs/reference/repository-guidance.md",
      "docs/research/agent-context-sources.md"
    ],
    "requireDocumentationStewardFromWave": 0,
    "requireContext7DeclarationsFromWave": 6,
    "requireExitContractsFromWave": 6,
    "requireIntegrationStewardFromWave": 0,
    "requireComponentPromotionsFromWave": 0,
    "requireAgentComponentsFromWave": 0
  },
  "capabilityRouting": {
    "preferredAgents": {}
  },
  "lanes": {
    "main": {
      "runtimePolicy": {
        "runtimeMixTargets": {
          "codex": 3,
          "claude": 3,
          "opencode": 2
        },
        "defaultExecutorByRole": {
          "implementation": "codex",
          "integration": "claude",
          "documentation": "claude",
          "evaluator": "claude",
          "research": "opencode",
          "infra": "opencode",
          "deploy": "opencode"
        },
        "fallbackExecutorOrder": ["claude", "opencode", "codex"]
      }
    }
  }
}
