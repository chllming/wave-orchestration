{
  "version": 1,
  "projectName": "Wave Orchestration",
  "repoMode": "single-repo",
  "defaultLane": "main",
  "paths": {
    "docsDir": "docs",
    "stateRoot": ".tmp",
    "orchestratorStateDir": ".tmp/wave-orchestrator",
    "terminalsPath": ".vscode/terminals.json",
    "context7BundleIndexPath": "docs/context7/bundles.json",
    "benchmarkCatalogPath": "docs/evals/benchmark-catalog.json",
    "componentCutoverMatrixDocPath": "docs/plans/component-cutover-matrix.md",
    "componentCutoverMatrixJsonPath": "docs/plans/component-cutover-matrix.json"
  },
  "roles": {
    "rolePromptDir": "docs/agents",
    "contQaAgentId": "A0",
    "contEvalAgentId": "E0",
    "integrationAgentId": "A8",
    "documentationAgentId": "A9",
    "contQaRolePromptPath": "docs/agents/wave-cont-qa-role.md",
    "contEvalRolePromptPath": "docs/agents/wave-cont-eval-role.md",
    "integrationRolePromptPath": "docs/agents/wave-integration-role.md",
    "documentationRolePromptPath": "docs/agents/wave-documentation-role.md",
    "securityRolePromptPath": "docs/agents/wave-security-role.md",
    "designRolePromptPath": "docs/agents/wave-design-role.md"
  },
  "executors": {
    "default": "codex",
    "profiles": {
      "implement-fast": {
        "id": "codex",
        "tags": ["implementation"],
        "budget": {
          "turns": 12,
          "minutes": 45
        }
      },
      "deep-review": {
        "id": "claude",
        "tags": ["integration", "review"],
        "budget": {
          "turns": 10,
          "minutes": 30
        }
      },
      "eval-tuning": {
        "id": "codex",
        "tags": ["eval", "tuning"],
        "budget": {
          "turns": 14,
          "minutes": 45
        }
      },
      "docs-pass": {
        "id": "claude",
        "tags": ["documentation"],
        "budget": {
          "turns": 8,
          "minutes": 20
        }
      },
      "design-pass": {
        "id": "claude",
        "tags": ["design", "review"],
        "budget": {
          "turns": 10,
          "minutes": 30
        },
        "claude": {
          "allowedTools": ["Read", "Edit", "Write", "Bash", "Grep", "Glob"]
        }
      },
      "planning-readonly": {
        "id": "codex",
        "model": "gpt-5-codex",
        "tags": ["planning", "review"],
        "budget": {
          "minutes": 30
        },
        "codex": {
          "search": true,
          "json": true,
          "sandbox": "read-only",
          "config": ["model_reasoning_effort=high"]
        }
      },
      "security-review": {
        "id": "claude",
        "tags": ["security", "review"],
        "budget": {
          "turns": 8,
          "minutes": 20
        },
        "claude": {
          "allowedTools": ["Read", "Edit", "Write", "Bash", "Grep", "Glob"]
        }
      },
      "ops-triage": {
        "id": "opencode",
        "tags": ["ops", "research"],
        "budget": {
          "turns": 8,
          "minutes": 20
        }
      }
    },
    "codex": {
      "command": "codex",
      "sandbox": "danger-full-access"
    },
    "claude": {
      "command": "claude",
      "appendSystemPromptMode": "append",
      "outputFormat": "text"
    },
    "opencode": {
      "command": "opencode",
      "format": "default"
    }
  },
  "skills": {
    "dir": "skills",
    "base": ["wave-core", "repo-coding-rules"],
    "byRole": {
      "design": ["role-design"],
      "implementation": ["role-implementation"],
      "integration": ["role-integration"],
      "documentation": ["role-documentation"],
      "cont-qa": ["role-cont-qa"],
      "cont-eval": ["role-cont-eval"],
      "security": ["role-security"],
      "infra": ["role-infra"],
      "deploy": ["role-deploy"],
      "research": ["role-research"]
    },
    "byRuntime": {
      "codex": ["runtime-codex"],
      "claude": ["runtime-claude"],
      "opencode": ["runtime-opencode"],
      "local": ["runtime-local"]
    },
    "byDeployKind": {
      "railway-cli": ["provider-railway"],
      "railway-mcp": ["provider-railway"],
      "docker-compose": ["provider-docker-compose"],
      "kubernetes": ["provider-kubernetes"],
      "aws": ["provider-aws"],
      "github-release": ["provider-github-release"],
      "ssh-manual": ["provider-ssh-manual"],
      "custom": ["provider-custom-deploy"]
    }
  },
  "planner": {
    "agentic": {
      "executorProfile": "planning-readonly",
      "defaultMaxWaves": 3,
      "maxReplanIterations": 1,
      "context7Bundle": "planner-agentic",
      "context7Query": "Wave planning best practices, maturity alignment, closure gates, proof surfaces, rollout evidence, and coordination failure prevention",
      "coreContextPaths": [
        "AGENTS.md",
        "wave.config.json",
        "docs/roadmap.md",
        "docs/plans/current-state.md",
        "docs/plans/master-plan.md",
        "docs/plans/wave-orchestrator.md",
        "docs/reference/sample-waves.md",
        "docs/plans/examples/wave-example-rollout-fidelity.md",
        "docs/plans/examples/wave-example-live-proof.md",
        "docs/reference/live-proof-waves.md",
        "docs/plans/component-cutover-matrix.md",
        "docs/plans/component-cutover-matrix.json",
        "docs/reference/wave-planning-lessons.md",
        "docs/research/coordination-failure-review.md"
      ],
      "lessonsPaths": [
        "docs/reference/wave-planning-lessons.md"
      ],
      "researchTopicPaths": [
        "docs/context7/planner-agent/topics/planning-and-orchestration.md"
      ]
    }
  },
  "sharedPlanDocs": [
    "docs/plans/current-state.md",
    "docs/plans/master-plan.md",
    "docs/plans/migration.md"
  ],
  "validation": {
    "requiredPromptReferences": [
      "docs/reference/repository-guidance.md",
      "docs/research/agent-context-sources.md"
    ],
    "requireDocumentationStewardFromWave": 0,
    "requireContext7DeclarationsFromWave": 6,
    "requireExitContractsFromWave": 6,
    "requireIntegrationStewardFromWave": 0,
    "requireComponentPromotionsFromWave": 0,
    "requireAgentComponentsFromWave": 0
  },
  "capabilityRouting": {
    "preferredAgents": {}
  },
  "lanes": {
    "main": {
      "runtimePolicy": {
        "runtimeMixTargets": {
          "codex": 7,
          "claude": 4,
          "opencode": 2
        },
        "defaultExecutorByRole": {
          "design": "claude",
          "implementation": "codex",
          "integration": "claude",
          "documentation": "claude",
          "cont-qa": "claude",
          "cont-eval": "codex",
          "security": "claude",
          "research": "opencode",
          "infra": "opencode",
          "deploy": "opencode"
        },
        "fallbackExecutorOrder": ["claude", "opencode", "codex"]
      }
    }
  }
}
